# Copy this file to .env and fill in your values. Never commit .env to git.

# AI API Keys (required for podcast generation)
GEMINI_API_KEY=
SARVAM_API_KEY=        # Hindi TTS (Sarvam bulbul:v2)
DEEPGRAM_API_KEY=      # English TTS (Deepgram Aura) — get free key at console.deepgram.com

# Supabase (persistent podcast list — survives Render restarts)
# Sign up free at https://supabase.com → create project → SQL Editor → run:
#   CREATE TABLE podcasts (id BIGINT PRIMARY KEY, name TEXT, description TEXT,
#     date TEXT, lang TEXT, audio_url TEXT, created_at TEXT);
# Then go to Project Settings → API to copy URL and anon key.
SUPABASE_URL=
SUPABASE_KEY=

# Cloudinary (for audio hosting) - use either CLOUDINARY_URL OR the 3 vars below
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=
# Or set individually:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

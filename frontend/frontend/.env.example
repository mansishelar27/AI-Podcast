# Copy this file to .env and adjust for your environment.
# Never commit .env to git (it's in .gitignore).
# React only exposes variables prefixed with REACT_APP_ to the browser.

# Backend API base URL (with or without /api/v1 - the app normalizes it)
# Local dev:
REACT_APP_API_URL=http://localhost:8000

# Production example (uncomment and set when deploying):
# REACT_APP_API_URL=https://your-backend.onrender.com/api/v1
